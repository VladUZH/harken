# Harken configuration — all optional. Copy to .env and edit as needed.
# Harken runs with ZERO configuration; everything below is an upgrade, not a requirement.

# --- Storage ---
# HARKEN_DB=harken.db

# --- Sources ---
# Comma-separated. Zero-config defaults: hackernews,reddit
# Other options: mastodon, bluesky, rss
# HARKEN_SOURCES=hackernews,reddit,bluesky
# HARKEN_LIMIT=50

# Mastodon: which public instance to search
# HARKEN_MASTODON_INSTANCE=mastodon.social

# RSS: comma-separated feed URLs (e.g. a Google Alerts RSS, a blog, a news feed)
# HARKEN_RSS_FEEDS=https://example.com/feed.xml,https://news.example/rss

# --- Optional LLM (for nicer theme labels). Local lexicon analysis is the default. ---
# Provider: none (default) | anthropic | openai | ollama
# HARKEN_LLM_PROVIDER=none
# HARKEN_LLM_MODEL=

# Anthropic (pip install anthropic)
# HARKEN_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# HARKEN_LLM_MODEL=claude-opus-4-8

# OpenAI-compatible (OpenAI, OpenRouter, Together, …)
# HARKEN_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# HARKEN_LLM_BASE_URL=https://api.openai.com/v1
# HARKEN_LLM_MODEL=gpt-4o-mini

# Ollama (fully local — your data never leaves your machine)
# HARKEN_LLM_PROVIDER=ollama
# HARKEN_LLM_HOST=http://localhost:11434
# HARKEN_LLM_MODEL=llama3.2
